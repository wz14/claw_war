# ============ LLM 配置（必填） ============
# AI 主持人走 OpenAI 兼容接口，默认 DeepSeek（性价比高、国内可用）
# 也可以换成 OpenAI 官方 / 月之暗面 Kimi / 智谱 GLM / 通义千问 / 本地 Ollama 等

# 必填：你的 API Key
OPENAI_API_KEY=sk-your-api-key-here

# 可选：API endpoint，默认 https://api.deepseek.com/v1
#   OpenAI:        https://api.openai.com/v1
#   月之暗面 Kimi: https://api.moonshot.cn/v1
#   智谱 GLM:      https://open.bigmodel.cn/api/paas/v4
#   通义千问:      https://dashscope.aliyuncs.com/compatible-mode/v1
#   本地 Ollama:   http://localhost:11434/v1
OPENAI_BASE_URL=https://api.deepseek.com/v1

# 可选：模型名，默认 deepseek-chat
#   OpenAI:    gpt-4o-mini / gpt-4o
#   Kimi:      moonshot-v1-8k
#   GLM:       glm-4-flash
#   通义:      qwen-turbo / qwen-plus
OPENAI_MODEL=deepseek-chat

# 可选：温度。0.7-0.9 戏剧效果最好（默认 0.8）
LLM_TEMPERATURE=0.8


# ============ 数据存储（可选） ============
# 持久化数据（龙虾、bot 凭证、战报）的目录，默认 ./data
CLAW_WAR_DATA_DIR=./data


# ============ 错误监控（可选） ============
# Sentry DSN：未捕获异常 + logger.error 自动上报到 Sentry 仪表盘并触发告警。
# 留空则跳过初始化，本地开发不影响。
# 在 https://sentry.io/ → 项目 → Settings → Client Keys (DSN) 获取
SENTRY_DSN=
